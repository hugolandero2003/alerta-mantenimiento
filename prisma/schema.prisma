generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Vehicle {
  id             String        @id @default(cuid())
  plate          String        @unique
  driverCc       String
  model          String
  company        String?
  phoneNumber    String?
  currentKm      Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  maintenances   Maintenance[]
  commercialLine String
  cargoBodyType  String
  driverName     String

  @@index([plate])
  @@index([plate, driverCc])
}

model Maintenance {
  id                  String               @id @default(cuid())
  vehicleId           String
  title               String
  maintenanceType     String?
  pesvSystem          String?
  serviceModality     String?
  currentKm           Int?
  description         String?
  dueDate             DateTime
  dueKm               Int?
  alarmAt             DateTime?
  notificationChannel NotificationChannel   @default(SMS)
  status              AlertStatus          @default(PENDING)
  notified            Boolean              @default(false)
  completedAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  vehicle             Vehicle              @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([dueDate, status])
  @@index([alarmAt, notified])
}

enum AlertStatus {
  PENDING
  SENT
  DONE
}

enum NotificationChannel {
  SMS
  WHATSAPP
}
